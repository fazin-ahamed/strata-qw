# Root environment variables (copy to .env.local)

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=strata
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ClickHouse
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=strata
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=strata-data

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# API
API_PORT=4000
API_URL=http://localhost:4000

# Frontend
FLARE_URL=http://localhost:3001
LYVO_URL=http://localhost:3002

# AI/ML
OPENAI_API_KEY=
WHISPER_MODEL=base
VISION_MODEL=clip

# Encryption
ENCRYPTION_KEY=your-32-character-encryption-key-here-change-this

# Notification Settings
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@strata.ai

# Feature Flags
ENABLE_MEETING_CAPTURE=true
ENABLE_VISUAL_SNIPPETS=true
ENABLE_CROSS_DOMAIN_INTELLIGENCE=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
NODE_ENV=development
