{
  "name": "strata",
  "version": "0.1.0",
  "description": "Strata - Unified AI Operating System for Business (Flare) and Personal Life (Lyvo)",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:migrate": "pnpm --filter @strata/database migrate",
    "db:seed": "pnpm --filter @strata/database seed"
  },
  "keywords": ["ai", "operating-system", "business-intelligence", "personal-ai"],
  "author": "Strata Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0",
    "turbo": "^2.9.5",
    "typescript": "^5.3.3"
  }
}
