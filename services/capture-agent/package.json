{
  "name": "@strata/capture-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Local desktop capture agent for meeting recording",
  "main": "src/main.ts",
  "scripts": {
    "dev": "electron .",
    "build": "tsc && electron-builder",
    "build:win": "npm run build -- --win",
    "build:mac": "npm run build -- --mac",
    "build:linux": "npm run build -- --linux",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@strata/shared": "*",
    "electron": "^28.0.0",
    "desktop-capturer": "^1.0.0",
    "bullmq": "^5.1.0",
    "redis": "^4.6.12",
    "fluent-ffmpeg": "^2.1.2",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/fluent-ffmpeg": "^2.1.24",
    "typescript": "^5.3.3",
    "electron-builder": "^24.9.1",
    "eslint": "^8.56.0"
  },
  "build": {
    "appId": "com.strata.capture-agent",
    "productName": "Strata Capture Agent",
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist/**/*",
      "src/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "entitlements": "build/entitlements.mac.plist",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
